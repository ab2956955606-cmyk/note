{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MyNotes AI",
  "version": "1.1.0",
  "identifier": "com.mynotes.ai",
  "build": {
    "beforeDevCommand": "powershell -ExecutionPolicy Bypass -File ../../../scripts/dev-desktop.ps1",
    "devUrl": "http://127.0.0.1:5173/MyNotes.html",
    "beforeBuildCommand": "powershell -ExecutionPolicy Bypass -File ../../../scripts/build-web.ps1",
    "frontendDist": "../../web/dist"
  },
  "app": {
    "windows": [
      {
        "title": "MyNotes AI",
        "label": "main",
        "width": 1280,
        "height": 820,
        "minWidth": 1080,
        "minHeight": 700,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi"],
    "externalBin": ["binaries/mynotes-api"]
  }
}
